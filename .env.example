# ============================================================================
# CREX Clone — environment variables
# Copy to `.env` (root) and fill in. Never commit real secrets.
# ============================================================================

# --- Backend (Express) ------------------------------------------------------
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL via Prisma) ---------------------------------------
# For serverless Postgres (e.g. Neon) add &connect_timeout=15 — scale-to-zero
# computes cold-start slower than Prisma's 5s default connect timeout.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# --- Redis (cache) ----------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Auth (NextAuth + JWT) --------------------------------------------------
JWT_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- External cricket data provider -----------------------------------------
# Which upstream to use: "cricapi" (local/dev) or "cricbuzz" (production).
CRICKET_PROVIDER="cricapi"

# CricAPI (cricapi.com) — used when CRICKET_PROVIDER=cricapi
CRICKET_API_URL="https://api.cricapi.com/v1"
CRICAPI_KEY="your-cricapi-key-here"

# Cricbuzz via RapidAPI — used when CRICKET_PROVIDER=cricbuzz
RAPIDAPI_HOST="cricbuzz-cricket.p.rapidapi.com"
RAPIDAPI_KEY="your-rapidapi-key-here"

# --- Frontend (Next.js, must be prefixed NEXT_PUBLIC_) ----------------------
NEXT_PUBLIC_API_URL="http://localhost:5000"
NEXT_PUBLIC_SOCKET_URL="http://localhost:5000"
