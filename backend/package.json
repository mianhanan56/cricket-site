{
  "name": "@crex/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate --schema=./prisma/schema.prisma && npx tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:studio": "dotenv -e ../.env -- prisma studio",
    "seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "seed:rankings": "ts-node-dev --transpile-only prisma/seedRankings.ts",
    "clean-seed": "ts-node-dev --transpile-only src/scripts/cleanSeed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "prisma": "^5.14.0",
    "socket.io": "^4.7.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2"
  }
}
